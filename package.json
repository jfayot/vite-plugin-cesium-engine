{
  "name": "vite-plugin-cesium-engine",
  "version": "1.6.0",
  "description": "Zero-config Vite plugin for @cesium/engine — handles assets, CESIUM_BASE_URL, and Ion token automatically.",
  "author": "jfayot",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfayot/vite-plugin-cesium-engine.git"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "cesium",
    "@cesium/engine",
    "3d"
  ],
  "homepage": "https://github.com/jfayot/vite-plugin-cesium-engine",
  "bugs": "https://github.com/jfayot/vite-plugin-cesium-engine/issues",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "virtual.d.ts"
  ],
  "main": "./dist/vite-plugin-cesium-engine.umd.cjs",
  "module": "./dist/vite-plugin-cesium-engine.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/vite-plugin-cesium-engine.js",
      "require": "./dist/vite-plugin-cesium-engine.umd.cjs"
    },
    "./virtual": {
      "types": "./virtual.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:react": "pnpm build && pnpm -F example-react build",
    "build:svelte": "pnpm build && pnpm -F example-svelte build",
    "build:vanilla-ts": "pnpm build && pnpm -F example-vanilla-ts build",
    "build:vue": "pnpm build && pnpm -F example-vue build",
    "build:all": "pnpm build && pnpm --parallel -r -F \"example-*\" build",
    "clean": "rimraf ./dist && pnpm --parallel -r clean",
    "clean:all": "pnpm --parallel -r clean:all && rimraf ./node_modules ./dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:react": "pnpm -F example-react dev",
    "dev:svelte": "pnpm -F example-svelte dev",
    "dev:vanilla-ts": "pnpm -F example-vanilla-ts dev",
    "dev:vue": "pnpm -F example-vue dev",
    "start:react": "pnpm -F example-react preview",
    "start:svelte": "pnpm -F example-svelte preview",
    "start:vanilla-ts": "pnpm -F example-vanilla-ts preview",
    "start:vue": "pnpm -F example-vue preview",
    "release": "pnpm build && npm publish",
    "ci:publish": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "@cesium/engine": ">=11.0.0",
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}